# Environment variables untuk Putry Laundry POS
# Copy file ini ke .env dan isi dengan nilai sebenarnya

# === LOKAL DEVELOPMENT (SQLite) ===
DATABASE_URL="file:./db/custom.db"

# === PRODUCTION (Supabase) ===
# Dapat dari Supabase Dashboard → Settings → Database → Connection string
# DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# DIRECT_URL="postgresql://postgres.[project]:[password]@aws-0-[region].supabase.com:5432/postgres"

# === NEXTAUTH (opsional, untuk auth) ===
NEXTAUTH_SECRET="generate-dengan-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
