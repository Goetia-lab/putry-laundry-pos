// Prisma schema for Laundry POS - 2 cabang with daily closing & main recap

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Branch {
  id                    String   @id @default(cuid())
  name                  String
  code                  String   @unique
  address               String?
  phone                 String?
  operationalFundAmount Int      @default(50000) // dana operasional disisihkan tiap hari untuk besok
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  transactions     Transaction[]
  dailyClosings    DailyClosing[]
  expenses         OperationalExpense[]
  mainRecapEntries MainRecapEntry[]
  customers        Customer[]
}

model Service {
  id        String   @id @default(cuid())
  category  String // Jasa, Sepatu, Gorden, Selimut, Bed Cover, Lain-lain
  name      String // Cuci Kering, Sneakers, dll
  variant   String? // Reguler, Express (null jika tidak ada varian)
  price     Int
  unit      String // KG, PSG, PCS, M2
  duration  String? // "2-3 Hari", "24 Jam"
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionItems TransactionItem[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  branchId  String?
  createdAt DateTime @default(now())

  branch    Branch?  @relation(fields: [branchId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id           String   @id @default(cuid())
  invoiceNo    String   @unique
  branchId     String
  customerId   String?
  customerName String
  customerPhone String?
  date         DateTime @default(now())
  pickupDate   DateTime? // tanggal pengambilan
  status       String   @default("PROSES") // PROSES, SELESAI, DIAMBIL
  paymentStatus String  @default("LUNAS") // LUNAS, BELUM_BAYAR
  subtotal     Int      @default(0) // total sebelum diskon
  discountPercent Int   @default(0) // persentase diskon loyalty
  discountAmount Int    @default(0) // nominal diskon
  totalAmount  Int // total setelah diskon
  paidAmount   Int      @default(0)
  changeAmount Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch   Branch    @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  items    TransactionItem[]
}

model TransactionItem {
  id            String @id @default(cuid())
  transactionId String
  serviceId     String?
  serviceName   String
  category      String
  variant       String?
  price         Int
  unit          String
  quantity      Float
  subtotal      Int
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  service     Service?    @relation(fields: [serviceId], references: [id])
}

model OperationalExpense {
  id        String   @id @default(cuid())
  branchId  String
  date      DateTime @default(now())
  category  String // LISTRIK, AIR, GAS, BENIH, DETERGEN, LAINNYA, GAJI
  description String
  amount    Int
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
}

model DailyClosing {
  id                     String   @id @default(cuid())
  branchId               String
  date                   DateTime @unique // per cabang? no - need compound. Use date+branch unique via closingDate
  closingDate            DateTime // tanggal tutup buku (tanggal lokal)
  grossIncome            Int // total pendapatan kotor dari transaksi
  transactionCount       Int
  operationalExpenses    Int // total pengeluaran operasional hari itu
  netIncome              Int // gross - expenses
  transferredToMain      Int // net yang masuk ke rekap utama (= netIncome)
  operationalFundRetained Int // dana operasional disisihkan untuk besok
  status                 String   @default("CLOSED") // CLOSED, OPEN
  closingTime            DateTime @default(now())
  notes                  String?
  createdAt              DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, closingDate])
}

model MainRecap {
  id               String   @id @default(cuid())
  recapDate        DateTime @unique // tanggal rekap (tanggal lokal)
  totalGrossIncome Int // total gross dari semua cabang
  totalExpenses    Int // total pengeluaran semua cabang
  totalNetIncome   Int // total net
  totalOperationalFundDisbursed Int // total dana operasional dikembalikan ke cabang
  grandTotal       Int // net masuk ke kas utama = totalNet - totalOperationalFundDisbursed
  status           String   @default("CLOSED")
  notes            String?
  createdAt        DateTime @default(now())

  entries MainRecapEntry[]
}

model MainRecapEntry {
  id          String @id @default(cuid())
  recapId     String
  branchId    String
  grossIncome Int
  expenses    Int
  netIncome   Int
  operationalFundDisbursed Int
  netToMain   Int // netIncome - operationalFundDisbursed

  recap  MainRecap @relation(fields: [recapId], references: [id], onDelete: Cascade)
  branch Branch    @relation(fields: [branchId], references: [id])
}
