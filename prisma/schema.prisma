// Prisma schema for Putry Laundry POS - PostgreSQL version (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // optional for push, required for migrate
}

model Branch {
  id                    String   @id @default(cuid())
  name                  String
  code                  String   @unique
  address               String?
  phone                 String?
  operationalFundAmount Int      @default(50000)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  transactions     Transaction[]
  dailyClosings    DailyClosing[]
  expenses         OperationalExpense[]
  mainRecapEntries MainRecapEntry[]
  customers        Customer[]
}

model Service {
  id        String   @id @default(cuid())
  category  String
  name      String
  variant   String?
  price     Int
  unit      String
  duration  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionItems TransactionItem[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  branchId  String?
  createdAt DateTime @default(now())

  branch    Branch?  @relation(fields: [branchId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id           String   @id @default(cuid())
  invoiceNo    String   @unique
  branchId     String
  customerId   String?
  customerName String
  customerPhone String?
  date         DateTime @default(now())
  pickupDate   DateTime?
  status       String   @default("PROSES")
  paymentStatus String  @default("LUNAS")
  subtotal     Int      @default(0)
  discountPercent Int   @default(0)
  discountAmount Int    @default(0)
  totalAmount  Int
  paidAmount   Int      @default(0)
  changeAmount Int      @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branch   Branch    @relation(fields: [branchId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])
  items    TransactionItem[]
}

model TransactionItem {
  id            String @id @default(cuid())
  transactionId String
  serviceId     String?
  serviceName   String
  category      String
  variant       String?
  price         Int
  unit          String
  quantity      Float
  subtotal      Int
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  service     Service?    @relation(fields: [serviceId], references: [id])
}

model OperationalExpense {
  id        String   @id @default(cuid())
  branchId  String
  date      DateTime @default(now())
  category  String
  description String
  amount    Int
  createdAt DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])
}

model DailyClosing {
  id                     String   @id @default(cuid())
  branchId               String
  date                   DateTime
  closingDate            DateTime
  grossIncome            Int
  transactionCount       Int
  operationalExpenses    Int
  netIncome              Int
  transferredToMain      Int
  operationalFundRetained Int
  status                 String   @default("CLOSED")
  closingTime            DateTime @default(now())
  notes                  String?
  createdAt              DateTime @default(now())

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, closingDate])
}

model MainRecap {
  id               String   @id @default(cuid())
  recapDate        DateTime @unique
  totalGrossIncome Int
  totalExpenses    Int
  totalNetIncome   Int
  totalOperationalFundDisbursed Int
  grandTotal       Int
  status           String   @default("CLOSED")
  notes            String?
  createdAt        DateTime @default(now())

  entries MainRecapEntry[]
}

model MainRecapEntry {
  id          String @id @default(cuid())
  recapId     String
  branchId    String
  grossIncome Int
  expenses    Int
  netIncome   Int
  operationalFundDisbursed Int
  netToMain   Int

  recap  MainRecap @relation(fields: [recapId], references: [id], onDelete: Cascade)
  branch Branch    @relation(fields: [branchId], references: [id])
}
