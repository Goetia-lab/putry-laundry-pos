{
  "services": {
    "putry-laundry-pos": {
      "root": ".",
      "framework": "nextjs",
      "buildCommand": "prisma generate && next build"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "putry-laundry-pos"
      }
    }
  ]
}
