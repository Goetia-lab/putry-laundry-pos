# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.production
.env.vercel
!.env.example

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/

# Database (SQLite local dev) — ignore *.db anywhere in the repo
# (Prisma creates the file relative to the schema dir, so it can land in
# prisma/db/ — match both root db/ and prisma/db/)
*.db
*.db-journal

# Build output
/standalone

# Uploads (user data)
/upload/*
!/upload/.gitkeep

# ZCode scripts & Caddy (local/dev config)
/.zscripts/
Caddyfile
.env*
